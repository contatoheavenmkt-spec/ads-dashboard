generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  password             String?
  name                 String?
  role                 String        @default("AGENCY")
  workspaceId          String?
  onboardingCompleted  Boolean       @default(false)
  stripeCustomerId     String?       @unique
  forcePasswordChange  Boolean       @default(false)
  workspace            Workspace?    @relation("MemberWorkspace", fields: [workspaceId], references: [id])
  ownedWorkspaces      Workspace[]   @relation("OwnedWorkspaces")
  subscription         Subscription?
  metaConnections      MetaConnection[]
  googleConnections    GoogleConnection[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("trial")
  status               String    @default("trialing")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  accountsLimit        Int       @default(3)
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  platform    String
  adAccountId String
  name        String
  bmId        String?
  bmName      String?
  accessToken String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceIntegrations WorkspaceIntegration[]
}

model Workspace {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation("OwnedWorkspaces", fields: [ownerId], references: [id])
  name          String
  slug          String   @unique
  logo          String?
  publicAccess  Boolean  @default(false)
  sharePassword String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integrations WorkspaceIntegration[]
  clients      User[]   @relation("MemberWorkspace")
}

model MetaConnection {
  id          String    @id @default(cuid())
  userId      String
  fbUserId    String
  accessToken String
  name        String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fbUserId])
}

model GoogleConnection {
  id           String   @id @default(cuid())
  userId       String
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model WorkspaceIntegration {
  id            String      @id @default(cuid())
  workspaceId   String
  integrationId String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, integrationId])
}

model AdminLog {
  id          String   @id @default(cuid())
  action      String
  targetId    String?
  details     String?
  adminIp     String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([targetId])
  @@index([createdAt])
}

model MetricsCache {
  id          String   @id @default(cuid())
  workspaceId String
  platform    String
  cacheKey    String
  data        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([workspaceId, platform, cacheKey])
  @@index([expiresAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  sessionId String
  ip        String?
  country   String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([userId])
  @@index([sessionId])
}

model ErrorLog {
  id            String   @id @default(cuid())
  path          String
  statusCode    Int?
  errorType     String
  errorMessage  String
  stackTrace    String?
  userId        String?
  sessionId     String?
  ip            String?
  resolved      Boolean  @default(false)
  fixSuggestion String?
  createdAt     DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([resolved])
}

model ActiveSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String?
  ip        String?
  country   String?
  path      String?
  userAgent String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([lastSeen])
}
