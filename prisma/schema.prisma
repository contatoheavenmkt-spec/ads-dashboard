generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  password             String?
  name                 String?
  role                 String        @default("AGENCY")
  workspaceId          String?
  onboardingCompleted  Boolean       @default(false)
  stripeCustomerId     String?       @unique
  workspace            Workspace?    @relation(fields: [workspaceId], references: [id])
  subscription         Subscription?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("trial")    // trial | start | plus | premium
  status               String    @default("trialing") // trialing | active | expired | canceled
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  accountsLimit        Int       @default(3)
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  platform    String
  adAccountId String
  name        String
  bmId        String?
  bmName      String?
  accessToken String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceIntegrations WorkspaceIntegration[]
}

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  publicAccess  Boolean  @default(false)
  sharePassword String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integrations WorkspaceIntegration[]
  clients      User[]
}

model MetaConnection {
  id          String    @id @default(cuid())
  fbUserId    String    @unique
  accessToken String
  name        String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model GoogleConnection {
  id           String   @id @default(cuid())
  email        String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkspaceIntegration {
  id            String      @id @default(cuid())
  workspaceId   String
  integrationId String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, integrationId])
}

model MetricsCache {
  id          String   @id @default(cuid())
  workspaceId String
  platform    String
  cacheKey    String
  data        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([workspaceId, platform, cacheKey])
  @@index([expiresAt])
}
