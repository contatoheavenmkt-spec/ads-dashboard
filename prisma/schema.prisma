generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  password             String?
  name                 String?
  role                 String        @default("AGENCY")
  workspaceId          String?
  onboardingCompleted  Boolean       @default(false)
  stripeCustomerId     String?       @unique
  forcePasswordChange  Boolean       @default(false)
  workspace            Workspace?    @relation("MemberWorkspace", fields: [workspaceId], references: [id])
  ownedWorkspaces      Workspace[]   @relation("OwnedWorkspaces")
  subscription         Subscription?
  metaConnections      MetaConnection[]
  googleConnections    GoogleConnection[]
  pushSubscriptions    PushSubscription[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("trial")
  status               String    @default("trialing")
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  accountsLimit        Int       @default(3)
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  platform    String
  adAccountId String
  name        String
  bmId        String?
  bmName      String?
  accessToken String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceIntegrations WorkspaceIntegration[]
}

model Workspace {
  id            String   @id @default(cuid())
  ownerId       String?
  owner         User?    @relation("OwnedWorkspaces", fields: [ownerId], references: [id])
  name          String
  slug          String   @unique
  logo          String?
  publicAccess  Boolean  @default(false)
  sharePassword String?
  // JSON com flags { showSpend, showRevenue, showMessages, ... }. null = auto
  // (mostra todas que têm dados, comportamento padrão antigo).
  visibleMetrics String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  integrations WorkspaceIntegration[]
  clients      User[]   @relation("MemberWorkspace")
  leads        Lead[]
}

model MetaConnection {
  id          String    @id @default(cuid())
  userId      String
  fbUserId    String
  accessToken String
  name        String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fbUserId])
}

model GoogleConnection {
  id           String   @id @default(cuid())
  userId       String
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model WorkspaceIntegration {
  id            String      @id @default(cuid())
  workspaceId   String
  integrationId String
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, integrationId])
}

model PendingSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  plan      String
  orderId   String
  createdAt DateTime @default(now())
}

model AdminLog {
  id          String   @id @default(cuid())
  action      String
  targetId    String?
  details     String?
  adminIp     String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([targetId])
  @@index([createdAt])
}

model MetricsCache {
  id          String   @id @default(cuid())
  workspaceId String
  platform    String
  cacheKey    String
  data        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([workspaceId, platform, cacheKey])
  @@index([expiresAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  sessionId String
  ip        String?
  country   String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([userId])
  @@index([sessionId])
}

model ErrorLog {
  id            String   @id @default(cuid())
  path          String
  statusCode    Int?
  errorType     String
  errorMessage  String
  stackTrace    String?
  userId        String?
  sessionId     String?
  ip            String?
  resolved      Boolean  @default(false)
  fixSuggestion String?
  createdAt     DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([resolved])
}

model Lead {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dados do lead
  name        String
  phone       String?
  email       String?
  source      String?  // "meta_messaging", "meta_lead_form", "google", "manual", etc.
  campaignId  String?  // opcional — vincula à campanha que originou o lead
  notes       String?

  // Funil: "novo" → "contato" → "negociando" → "vendido" / "perdido"
  status      String   @default("novo")

  // Quem fechou (user do workspace que registrou a venda). Pode ser AGENCY
  // ou CLIENT — qualquer membro do workspace pode marcar vendido.
  closedByUserId String?
  closedAt    DateTime?
  saleValue   Float?

  // Auditoria
  createdByUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([campaignId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  // Snapshot de user.role no momento da criação. Usado pra segmentar
  // notificações (AGENCY recebe avisos de plano/integração; CLIENT recebe
  // avisos de campanha/saldo/resumo). Atualizado se o user mudar de role.
  role      String
  // workspaceId snapshot — preenchido só pra users CLIENT, viabiliza
  // disparar notificação "do workspace X" sem consultar User a cada vez.
  workspaceId String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([role])
  @@index([workspaceId])
}

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  type        String   // "campaign_active", "balance_low", "daily_digest", etc.
  title       String
  body        String
  url         String?
  // Chave de deduplicação por dia. Ex.: "campaign_active:cmp_123:2026-05-15".
  // Antes de enviar checamos se já existe NotificationLog com esse dedupeKey
  // pra evitar spammar o mesmo aviso a cada tick do cron.
  dedupeKey   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([dedupeKey])
  @@index([createdAt])
}

model CampaignSnapshot {
  id              String   @id @default(cuid())
  workspaceId     String
  campaignId      String
  // Snapshot do que o cron viu na última passada. Usado pra detectar
  // mudança de status (ACTIVE→PAUSED, novo campaign aparecendo, etc.).
  name            String
  status          String
  spend           Float    @default(0)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([workspaceId, campaignId])
  @@index([workspaceId])
}

model ActiveSession {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String?
  ip        String?
  country   String?
  path      String?
  userAgent String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([lastSeen])
}
